{
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "nodenext",
    "target": "ES2023",
    "outDir": "out",
    "sourceMap": true,
    "rootDir": "src",
    /* Strict Type-Checking Option */
    "strict": true,   /* enable all strict type-checking options */
    "skipLibCheck": true,
    /* Additional Checks */
    "noUnusedLocals": false /* Report errors on unused locals. */
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "eslint.config.mts"
    ]
}
